
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read and write access for development purposes.
    // WARNING: This is insecure for production. Secure your rules before launch.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
