
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Updated function to verify the Super Admin by a specific, hardcoded email.
    // The user must be authenticated, their email must match, and it must be verified.
    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'menu@i369.com' &&
             request.auth.token.email_verified == true;
    }

    // Public collections remain readable by anyone, but are only writable by the Super Admin.
    match /{collectionName}/{docId}
      where collectionName in ['projects', 'content', 'printRates'] {
        allow read: if true;
        allow write: if isSuperAdmin();
    }

    // Rules for the 'users' collection are now more secure.
    match /users/{userId} {
      // Users can read their own data, and the Super Admin can read any user's data.
      allow read: if request.auth.uid == userId || isSuperAdmin();
      
      // NEW CREATE RULE:
      // This rule allows two scenarios for document creation in the 'users' collection:
      // 1. A user is creating THEIR OWN document, but they are NOT allowed to include a 'role' field.
      //    This prevents self-escalation of privileges.
      // 2. The request is being made by the designated Super Admin. This allows the admin
      //    to create other users and assign them roles via the admin panel.
      allow create: if (request.auth.uid == userId && !('role' in request.resource.data)) || isSuperAdmin();

      // Only the Super Admin can update user documents (e.g., to change roles).
      allow update: if isSuperAdmin();

      // Only the Super Admin can delete user documents.
      allow delete: if isSuperAdmin();
    }

    // Quotations remain internal and should only be accessed by the Super Admin.
    match /quotations/{quoteId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
