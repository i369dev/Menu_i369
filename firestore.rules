rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Logged in ඕනෑම කෙනෙක්ට සියලුම දත්ත කියවන්න (Read) පුළුවන්.
    // මෙය App එක Permission Denied වී Crash වීම සම්පූර්ණයෙන්ම වළක්වයි.
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // 2. 'users' collection එකට දත්ත ඇතුලත් කරන්න/වෙනස් කරන්න පුළුවන් Super Admin ට පමණි.
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.token.email == 'menu@i369.com';
    }

    // 3. 'users' හැර අනෙකුත් ඕනෑම Collection එකකට දත්ත ලියන්න Log වුණු ඕනෑම කෙනෙක්ට පුළුවන්.
    match /{collectionName}/{document=**} {
      allow write: if request.auth != null && collectionName != 'users';
    }
    
  }
}