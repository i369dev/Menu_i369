rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'menu@i369.com' &&
             request.auth.token.email_verified;
    }
    
    // Function to check if the user has an admin or sales role in their user document
    function hasSalesOrAdminRole() {
      if (request.auth == null) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.role == 'Super Admin' || userDoc.data.role == 'Sales';
    }

    // Publicly readable collections
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /printRates/{rateId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 'quotations' collection accessible by sales and admins
    match /quotations/{quoteId} {
      allow read, write: if hasSalesOrAdminRole();
    }

    // 'users' collection with specific restrictions
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if isSuperAdmin();
      allow create: if (request.auth != null && request.auth.uid == userId && !('role' in request.resource.data)) || isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // This is a less-specific rule that will not override the more specific rules above.
    // It ensures any other collections remain private to the Super Admin.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
