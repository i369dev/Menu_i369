
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A function to check if the user is the hardcoded Super Admin via email.
    function isEmailSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'menu@i369.com';
    }

    // A function to check if the user has the 'Super Admin' role in their Firestore document.
    function isRoleSuperAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super Admin';
    }

    // A user is considered a Super Admin if they are the hardcoded email OR have the role.
    function isSuperAdmin() {
      return isEmailSuperAdmin() || isRoleSuperAdmin();
    }

    // A function to check if a user is the owner of a document.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Public collections are readable by anyone, but only writable by a Super Admin.
    match /{collectionName}/{docId}
      where collectionName in ['projects', 'content', 'printRates'] {
        allow read: if true;
        allow write: if isSuperAdmin();
    }

    // Rules for the 'users' collection.
    match /users/{userId} {
      // A Super Admin can read any user's profile and list all users.
      // Other authenticated users can only get their own profile.
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      
      // A Super Admin can update or delete any user profile.
      allow update, delete: if isSuperAdmin();

      // Creation rules:
      // 1. A Super Admin can create any user profile (for UserManager).
      // 2. Any other user can create their own profile, but cannot assign a 'role'.
      allow create: if isSuperAdmin() || (isOwner(userId) && !('role' in request.resource.data));
    }

    // Quotations can only be read or written by a Super Admin.
    // This could be expanded to include a 'Sales' role if needed in the future.
    match /quotations/{quoteId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
