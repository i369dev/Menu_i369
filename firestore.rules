
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Function to check for the hardcoded Super Admin email.
    // This user is the root administrator.
    function isEmailSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'menu@i369.com' &&
             request.auth.token.email_verified == true;
    }

    // Function to check if a user has been granted the 'Super Admin' role
    // in their user document. This allows for role delegation.
    function isRoleSuperAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super Admin';
    }

    // A user is considered a Super Admin if they are the hardcoded email OR have the role.
    function isSuperAdmin() {
      return isEmailSuperAdmin() || isRoleSuperAdmin();
    }
    
    // A function to check if a user has the 'Sales' role.
    function isSales() {
       return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Sales';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Public collections are readable by anyone, but only writable by a Super Admin.
    match /{collectionName}/{docId}
      where collectionName in ['projects', 'content', 'printRates'] {
        allow read: if true;
        allow write: if isSuperAdmin();
    }

    // Rules for the 'users' collection.
    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
      
      // Allow user creation if it's the admin doing it,
      // OR if a new user is creating their own profile without assigning a role.
      allow create: if isSuperAdmin() || (isOwner(userId) && !('role' in request.resource.data));
    }

    // Quotations can be read/written by Super Admins and Sales role.
    match /quotations/{quoteId} {
      allow read, write: if isSuperAdmin() || isSales();
    }
  }
}
