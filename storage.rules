
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // A function to check if the requesting user is the designated Super Admin.
    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'menu@i369.com';
    }

    match /{allPaths=**} {
      // Allow public read access to all files.
      allow read: if true;

      // Allow write access (create, update, delete) only for the authenticated Super Admin.
      allow write: if isSuperAdmin();
    }
  }
}
