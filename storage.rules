
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // A function to check if the requesting user is a Super Admin.
    // This mirrors the logic in firestore.rules for consistency.
    function isSuperAdmin() {
      return request.auth != null &&
             exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Super Admin';
    }

    match /{allPaths=**} {
      // Allow public read access to all files.
      allow read: if true;

      // Allow write access (create, update, delete) only for authenticated Super Admins.
      allow write: if isSuperAdmin();
    }
  }
}
