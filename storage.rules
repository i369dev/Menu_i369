rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // WARNING: These rules are temporary and highly permissive.
      // They allow any authenticated user to read and write to any path in your storage bucket.
      // Replace these with more restrictive rules as soon as possible for production environments.
      allow read, write: if request.auth != null;
    }
  }
}
